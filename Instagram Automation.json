{
  "name": "AI Social Media Lead Generation System",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// In n8n, webhook GET query params are in input.query\nconst query = input.query || {};\n\nconst mode = (query['hub.mode'] || '').toString();\nconst token = (query['hub.verify_token'] || '').toString();\nconst challenge = (query['hub.challenge'] || '').toString();\n\nconst VERIFY_TOKEN = 'YOUR_VERIFY_TOKEN';\n\nreturn [{\n  json: {\n    verified: (\n      mode === 'subscribe' &&\n      token === VERIFY_TOKEN\n    ),\n    challenge: challenge\n  }\n}];"
      },
      "id": "76132b98-e915-4bfc-af6e-3839ef8ef337",
