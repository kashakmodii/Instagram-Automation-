      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nlet aiText = '';\n\ntry {\n  // chainLlm typically returns {text: '...'} or {output: '...'}\n  if (item.text && typeof item.text === 'string' && item.text.trim()) {\n    aiText = item.text.trim();\n  } else if (item.output && typeof item.output === 'string' && item.output.trim()) {\n    aiText = item.output.trim();\n  } else if (item.response && typeof item.response === 'string' && item.response.trim()) {\n    aiText = item.response.trim();\n  } else if (item.message && item.message.content) {\n    aiText = item.message.content.toString().trim();\n  } else if (item.choices && Array.isArray(item.choices) && item.choices[0] && item.choices[0].message) {\n    aiText = item.choices[0].message.content.toString().trim();\n  } else if (typeof item === 'string') {\n    aiText = item.trim();\n  }\n} catch(e) {\n  aiText = '';\n}\n\n// Strip any accidental markdown\naiText = aiText.replace(/```[\\s\\S]*?```/g, '').trim();\n\n// Enforce safe fallback\nif (!aiText || aiText.length < 2) {\n  aiText = 'Thanks for reaching out! How can I assist you today? 😊';\n}\n\n// Truncate to safe Instagram DM limit (1000 chars)\nif (aiText.length > 1000) {\n  aiText = aiText.substring(0, 997) + '...';\n}\n\nlet prevData;\ntry {\n  prevData = $('Normalize Data').first().json;\n} catch(e) {\n  prevData = {};\n}\n\nreturn [{\n  json: {\n    type: prevData.type || 'dm',\n    username: prevData.username || '',\n    user_id: prevData.user_id || '',\n    message: prevData.message || '',\n    post_id: prevData.post_id || '',\n    page_id: prevData.page_id || '',\n    timestamp: prevData.timestamp || new Date().toISOString(),\n    normalized_at: prevData.normalized_at || new Date().toISOString(),\n    chatbot_reply: aiText\n  }\n}];"
      },
